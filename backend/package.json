{
  "name": "casecellshop-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --no-warnings -r tsx/cjs src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --no-warnings --test --require tsx/cjs tests/products.test.ts tests/checkout.test.ts",
    "test:concurrency": "node --no-warnings -r tsx/cjs tests/concurrency.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "supertest": "^7.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
